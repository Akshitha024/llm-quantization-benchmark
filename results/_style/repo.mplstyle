# Silicon Twilight palette for this repo. Re-rendered charts pick this up.
axes.facecolor: #03045E
figure.facecolor: #03045E
axes.edgecolor: #FFFFFF
axes.labelcolor: #FFFFFF
axes.titlecolor: #FFFFFF
axes.titleweight: bold
xtick.color: #FFFFFF
ytick.color: #FFFFFF
grid.color: #0077B6
grid.alpha: 0.5
axes.grid: True
axes.spines.top: False
axes.spines.right: False
axes.prop_cycle: cycler('color', [#03045E, #0077B6, #00B4D8, #90E0EF, #CAF0F8, #FB8500])
font.family: sans-serif
font.sans-serif: Helvetica, Arial, DejaVu Sans
font.size: 10
figure.titlesize: 14
figure.titleweight: bold
image.cmap: viridis
